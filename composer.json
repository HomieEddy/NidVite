{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anhskohbo/no-captcha": "^3.8",
        "bacon/bacon-qr-code": "^3.1",
        "barryvdh/laravel-dompdf": "^3.1",
        "bepsvpt/secure-headers": "^9.1",
        "filament/filament": "^5.6",
        "intervention/image": "^3.11",
        "jenssegers/agent": "^2.6",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^11.0",
        "laravel/reverb": "^1.10",
        "laravel/tinker": "^2.9",
        "maatwebsite/excel": "^3.1",
        "pragmarx/google2fa-laravel": "^3.0",
        "predis/predis": "^2.3",
        "resend/resend-laravel": "^1.3",
        "sentry/sentry-laravel": "^4.25",
        "silviolleite/laravelpwa": "^2.0",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-backup": "^9.0",
        "spatie/laravel-health": "^1.39",
        "spatie/laravel-honeypot": "^4.7",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-responsecache": "^7.7",
        "spatie/laravel-schedule-monitor": "^4.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.0",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "laravel/telescope": "^5.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "nunomaduro/larastan": "^2.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-faker": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --ansi"
        ],
        "quality:phpstan-stage6": [
            "./vendor/bin/phpstan analyse --configuration=phpstan.stage6.neon --no-progress --memory-limit=1G"
        ],
        "quality:rector-dry-run": [
            "rector process --dry-run --config rector.php app/Actions/Reports app/Filament/Resources/Reports/Schemas app/Filament/Resources/RepairJobs/Schemas"
        ],
        "test:host": [
            "powershell -ExecutionPolicy Bypass -File scripts/test-host.ps1"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "11.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
