APP_NAME=NidVite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Toronto
APP_URL=http://localhost:8091

# Disable Debugbar in local dev for performance (Windows Docker file I/O is slow)
DEBUGBAR_ENABLED=false

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_CA

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=nidvite
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# Keep false for local HTTP (APP_URL=http://...). Set true in production HTTPS.
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null
ADMIN_SESSION_TIMEOUT_MINUTES=15
ADMIN_MAX_CONCURRENT_SESSIONS=2

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
MEDIA_DISK=${FILESYSTEM_DISK}
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_DRIVER=database
RESPONSE_CACHE_LIFETIME=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@nidvite.ca"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (Production Email)
RESEND_API_KEY=

# Google reCAPTCHA
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=

# Reverb (WebSockets)
REVERB_APP_ID=local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8089
REVERB_SCHEME=http
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Sail Port Configuration (avoid conflicts with existing containers)
WWWGROUP=1000
WWWUSER=1000
APP_PORT=8091
VITE_PORT=5174
REVERB_PORT=8089
FORWARD_DB_PORT=5437
FORWARD_REDIS_PORT=6381
FORWARD_MAILPIT_PORT=1026
FORWARD_MAILPIT_DASHBOARD_PORT=8026

# Xdebug (set to 'develop' to enable debugging, 'off' for performance)
SAIL_XDEBUG_MODE=off

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (production object storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=
R2_DEFAULT_REGION=auto
R2_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 cold storage (archive)
R2_COLD_ACCESS_KEY_ID=
R2_COLD_SECRET_ACCESS_KEY=
R2_COLD_BUCKET=
R2_COLD_ENDPOINT=
R2_COLD_URL=
R2_COLD_DEFAULT_REGION=auto
R2_COLD_USE_PATH_STYLE_ENDPOINT=false

# Backups (spatie/laravel-backup)
BACKUP_DISK=r2
BACKUP_NOTIFY_EMAIL=
BACKUP_MONITOR_MAX_MB=20480

# Health checks (spatie/laravel-health)
HEALTH_NOTIFY_EMAIL=
HEALTH_QUEUE_MAX_AGE_MINUTES=5
HEALTH_DISK_WARN_PERCENT=80
HEALTH_DISK_FAIL_PERCENT=90
HEALTH_SCHEDULE_MAX_AGE_MINUTES=2

# Data retention
RETENTION_IP_PURGE_DAYS=30
RETENTION_REPORT_ARCHIVE_DAYS=730
RETENTION_COLD_STORAGE_DISK=r2-cold
RETENTION_COLD_STORAGE_PREFIX=cold/reports

# Suspicious activity detection
SUSPICIOUS_RAPID_REPEAT_WINDOW_MINUTES=5
SUSPICIOUS_RAPID_REPEAT_THRESHOLD=3
SUSPICIOUS_GEO_WINDOW_MINUTES=30
SUSPICIOUS_GEO_MAX_TRAVEL_MINUTES=10
SUSPICIOUS_GEO_MIN_DISTANCE_METERS=5000

VITE_APP_NAME="${APP_NAME}"

# Secure headers
SECURE_HEADERS_HSTS_ENABLE=true
SECURE_HEADERS_HSTS_MAX_AGE=31536000
SECURE_HEADERS_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HEADERS_HSTS_PRELOAD=false
