APP_NAME=NidVite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=nid_vite
DB_USERNAME=sail
DB_PASSWORD=password

# Queue
QUEUE_CONNECTION=database

# Cache
CACHE_DRIVER=database

# Session Security
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_LIFETIME=15

# Mail
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="updates@nidvite.ca"
MAIL_FROM_NAME="NidVite"

# File Storage
FILESYSTEM_DISK=local

# reCAPTCHA
NOCAPTCHA_SECRET=
NOCAPTCHA_SITEKEY=

# MapTiler
MAPTILER_API_KEY=

# Cloudflare R2 (production)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nidvite-media
R2_ENDPOINT=
R2_URL=

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Reverb (real-time)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Broadcasting
BROADCAST_DRIVER=reverb
