# Railway staging environment template for NidVite
# Created: 2026-05-08
#
# Applied already via CLI (safe defaults + references):
# APP_NAME, APP_ENV, APP_KEY, APP_DEBUG, APP_LOCALE, APP_FALLBACK_LOCALE,
# DB_CONNECTION, DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD,
# QUEUE_CONNECTION, CACHE_STORE, REDIS_HOST, REDIS_PORT, REDIS_PASSWORD,
# SESSION_DRIVER, SESSION_SECURE_COOKIE, SESSION_HTTP_ONLY, SESSION_SAME_SITE,
# FILESYSTEM_DISK, MEDIA_DISK, R2_DEFAULT_REGION, R2_USE_PATH_STYLE_ENDPOINT,
# MAIL_MAILER, MAIL_FROM_NAME, BROADCAST_CONNECTION
#
# Fill and set the remaining required keys before demo launch.

APP_NAME=NidVite
APP_ENV=staging
APP_DEBUG=false
APP_KEY=<generated-and-set-in-railway>
APP_URL=https://your-staging-domain
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# Required for Railway Nixpacks build because frontend deps require Node >= 20
NIXPACKS_NODE_VERSION=20

DB_CONNECTION=pgsql
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_DATABASE=${{Postgres.PGDATABASE}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# PostGIS must be available on this DB service for reports migration

QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=r2
MEDIA_DISK=r2
R2_DEFAULT_REGION=auto
R2_USE_PATH_STYLE_ENDPOINT=false
R2_ACCESS_KEY_ID=<required>
R2_SECRET_ACCESS_KEY=<required>
R2_BUCKET=<required>
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_URL=https://<your-media-domain>

MAIL_MAILER=log
MAIL_FROM_NAME=NidVite
MAIL_FROM_ADDRESS=noreply@your-domain

BROADCAST_CONNECTION=log

NOCAPTCHA_SITEKEY=<required>
NOCAPTCHA_SECRET=<required>

# Optional, only if/when switching staging mailer away from log:
RESEND_API_KEY=<optional-for-staging>
